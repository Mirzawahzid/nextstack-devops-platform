{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "NextStack Application Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "description": "Total number of HTTP requests per second hitting the NextStack app. Helps identify traffic spikes and load patterns.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"nextstack\"}[2m])) by (method, status)",
          "legendFormat": "{{method}} {{status}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "HTTP Error Rate (4xx / 5xx)",
      "description": "Percentage of requests returning 4xx or 5xx error codes. A spike here indicates bugs, misconfigurations or overload.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"nextstack\",status=~\"4..|5..\"}[2m])) / sum(rate(http_requests_total{namespace=\"nextstack\"}[2m]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Pod CPU Usage (%)",
      "description": "CPU utilisation per pod in the nextstack namespace. Used to detect CPU throttling and plan horizontal scaling.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"nextstack\",container=\"nextstack\"}[2m])) by (pod) * 100",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Pod Memory Usage (MB)",
      "description": "Memory consumption per pod in real-time. Helps catch memory leaks before they cause OOMKill events.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 240 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"nextstack\",container=\"nextstack\"}) by (pod) / 1024 / 1024",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Pod Availability (Running Pods)",
      "description": "Number of Running vs Desired replicas. Instantly shows if a pod has crashed or been evicted — critical for SLA monitoring.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"nextstack\",phase=\"Running\"})",
          "legendFormat": "Running Pods",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "API Response Time (P95 Latency)",
      "description": "95th percentile response time for all HTTP endpoints. Values above 500ms indicate performance degradation needing investigation.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_milliseconds_bucket{namespace=\"nextstack\"}[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "Health Probe Status (Liveness & Readiness)",
      "description": "Tracks success rate of /healthz (liveness) and /ready (readiness) probes. Failures here cause pod restarts or traffic removal by Kubernetes.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_ready{namespace=\"nextstack\",container=\"nextstack\"}) by (pod)",
          "legendFormat": "Readiness — {{pod}}",
          "refId": "A"
        },
        {
          "expr": "sum(kube_pod_container_status_last_terminated_reason{namespace=\"nextstack\",reason=\"Error\"}) by (pod)",
          "legendFormat": "Liveness Failures — {{pod}}",
          "refId": "B"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["nextstack", "kubernetes", "devops"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NextStack – Application Dashboard",
  "uid": "nextstack-dashboard-v1",
  "version": 1
}
